# Generated by Cargo
# will have compiled files and executables
debug
target

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Generated by cargo mutants
# Contains mutation testing data
**/mutants.out*/

# RustRover
#  JetBrains specific template is maintained in a separate JetBrains.gitignore that can
#  be found at https://github.com/github/gitignore/blob/main/Global/JetBrains.gitignore
#  and can be added to the global gitignore or merged into this file.  For a more nuclear
#  option (not recommended) you can uncomment the following to ignore the entire idea folder.
#.idea/
book/book
lab-out/
.superpowers/

# 10k author-time census output; committed charts come from census-lands-drift only
book/src/laboratory/generated/census-of-lands/
book/src/laboratory/generated/census-of-peoples/
book/src/laboratory/generated/census-of-faiths/
book/src/laboratory/generated/census-of-eyes/
book/src/laboratory/generated/census-of-tongues/
book/src/laboratory/generated/census-of-words/

# census-of-figures: a dev-time calibration instrument (night-sky stage 3,
# figure-threshold freeze), not a committed census fixture — the study json
# + metrics are committed, its rows.csv/summary output is not.
book/src/laboratory/generated/census-of-figures/

# Claude Code: project skills and shared settings (Bash timeout budget) are
# committed; personal settings.local.json and worktrees are not
.claude/*
!.claude/skills/
!.claude/settings.json
__pycache__/
*.pyc

# Throwaway census analysis database (tools/census/build.sh output)
tools/census/.build/

# The Casement: the .wasm is deploy-built, never committed (decision 0052);
# the wasm crate is outside the workspace so it has its own target/.
book/src/gallery/vessel.wasm
clients/vessel/wasm/target/
